[include]
	path = ~/.gitconfig-local
[core]
	excludesFile = ~/.gitignore
	pager = less -FMRiX
[push]
	default = simple
[alias]
	dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)%an <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order
[color]
	ui = auto
[merge]
	tool = nvimdiff
[mergetool "nvimdiff"]
	cmd = nvim -d $LOCAL $REMOTE $MERGED
[mergetool]
	prompt = false
